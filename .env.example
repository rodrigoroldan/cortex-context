# Cortex Context — environment variables
# Copy to .env and fill in the required values.

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-please

# ── API ──────────────────────────────────────────────────────────────────────
# Bearer token required on all API requests (Authorization: Bearer <token>)
CORTEX_API_TOKEN=change-me-please
CORTEX_PORT=8082
CORTEX_HOST=0.0.0.0

# ── Sources ──────────────────────────────────────────────────────────────────
# Path to your specs directory (mounted into the container as /specs)
# Example: /home/user/my-workspace/specs
SPECS_DIR=/path/to/your/specs

# Path to a directory containing service manifest files (AGENTS.md / agents.md)
# Used as a local fallback when source_type: github_api is unavailable.
# Leave empty if using github_api source exclusively.
REPOS_DIR=/path/to/your/repos

# GitHub personal access token (scope: contents:read)
# Required only when source_type: github_api is used for private repos.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ── Embeddings (optional) ────────────────────────────────────────────────────
# CORTEX_EMBEDDING_PROVIDER=none    # default — FTS-only, no extra dependencies
# CORTEX_EMBEDDING_PROVIDER=local   # offline, 384 dims (sentence-transformers)
# CORTEX_EMBEDDING_PROVIDER=openai  # 1536 dims, requires OPENAI_API_KEY
CORTEX_EMBEDDING_PROVIDER=none
# CORTEX_EMBEDDING_MODEL=all-MiniLM-L6-v2
# OPENAI_API_KEY=sk-...

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
