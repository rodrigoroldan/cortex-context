# Cortex — variáveis de ambiente
# Copie para .env e preencha os valores reais

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=PREENCHA_AQUI

# API
CORTEX_API_TOKEN=PREENCHA_AQUI
CORTEX_PORT=8082
CORTEX_HOST=0.0.0.0

# Ingestor
SPECS_DIR=/path/to/role-organizado-workspace/specs
# Token GitHub para fetch de AGENTS.md em repos privados via POST /api/v1/ingest/agents
# Gere em: https://github.com/settings/tokens (escopo: contents:read)
# Sem token: usa fetch anônimo (funciona apenas em repos públicos)
GITHUB_TOKEN=
# Diretório com AGENTS.md dos repos (fallback local quando GitHub indisponível)
# Em produção (LXC 200): /opt/cortex-repos
REPOS_DIR=/path/to/cortex-repos

# App
APP_ENV=development
LOG_LEVEL=INFO
