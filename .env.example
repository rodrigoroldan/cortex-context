# Cortex — variáveis de ambiente
# Copie para .env e preencha os valores reais

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=PREENCHA_AQUI

# API
CORTEX_API_TOKEN=PREENCHA_AQUI
CORTEX_PORT=8082
CORTEX_HOST=0.0.0.0

# Ingestor
SPECS_DIR=/path/to/role-organizado-workspace/specs

# App
APP_ENV=development
LOG_LEVEL=INFO
