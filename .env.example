# Cortex — variáveis de ambiente
# Copie para .env e preencha os valores reais

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=PREENCHA_AQUI

# API
CORTEX_API_TOKEN=PREENCHA_AQUI
CORTEX_PORT=8082
CORTEX_HOST=0.0.0.0

# Ingestor
SPECS_DIR=/path/to/role-organizado-workspace/specs
# Diretório contendo os AGENTS.md dos repos clonados (para POST /api/v1/ingest/agents)
# Estrutura esperada: ${REPOS_DIR}/{repo-name}/AGENTS.md ou {repo-name}/agents.md
# Em produção (LXC 200): /opt/cortex-repos
REPOS_DIR=/path/to/cortex-repos

# App
APP_ENV=development
LOG_LEVEL=INFO
